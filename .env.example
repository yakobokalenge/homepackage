# =============================================================================
# HomePackage — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control
# =============================================================================

# =============================================================================
# General
# =============================================================================
ENVIRONMENT=development
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,homepackage.co.tz
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# =============================================================================
# Django
# =============================================================================
SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_SETTINGS_MODULE=homepackage.settings.development

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
POSTGRES_DB=homepackage
POSTGRES_USER=homepackage
POSTGRES_PASSWORD=homepackage_dev_2026
DATABASE_URL=postgres://homepackage:homepackage_dev_2026@db:5432/homepackage

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# =============================================================================
# JWT Authentication
# =============================================================================
JWT_ACCESS_TOKEN_LIFETIME=30
JWT_REFRESH_TOKEN_LIFETIME=10080

# =============================================================================
# Google OAuth 2.0
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# Payment Gateways — Tanzania
# =============================================================================

# --- Flutterwave (Primary) ---
# Get keys from: https://dashboard.flutterwave.com/settings/apis
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_WEBHOOK_HASH=
FLUTTERWAVE_ENVIRONMENT=sandbox

# --- ClickPesa ---
# Get keys from: https://dashboard.clickpesa.com/developers
CLICKPESA_CLIENT_ID=
CLICKPESA_API_KEY=
CLICKPESA_WEBHOOK_SECRET=
CLICKPESA_ENVIRONMENT=sandbox

# --- AzamPay ---
# Get keys from: https://developers.azampay.co.tz
AZAMPAY_APP_NAME=
AZAMPAY_CLIENT_ID=
AZAMPAY_CLIENT_SECRET=
AZAMPAY_API_KEY=
AZAMPAY_ENVIRONMENT=sandbox

# --- Selcom (Optional) ---
SELCOM_VENDOR_ID=
SELCOM_API_KEY=
SELCOM_API_SECRET=
SELCOM_ENVIRONMENT=sandbox

# =============================================================================
# File Storage
# =============================================================================

# --- AWS S3 (Video Recordings) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=homepackage-proctoring
AWS_S3_REGION_NAME=af-south-1
AWS_S3_CUSTOM_DOMAIN=

# --- Cloudinary (Images) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# =============================================================================
# Email
# =============================================================================
# Resend (recommended for transactional email)
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=noreply@homepackage.co.tz

# SendGrid (alternative)
# SENDGRID_API_KEY=

# =============================================================================
# SMS — Africa's Talking
# =============================================================================
# Get keys from: https://account.africastalking.com
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=HomePackage
AFRICASTALKING_ENVIRONMENT=sandbox

# =============================================================================
# Frontend (Vite)
# =============================================================================
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_FLUTTERWAVE_PUBLIC_KEY=
VITE_GOOGLE_CLIENT_ID=
VITE_APP_NAME=HomePackage
VITE_DEFAULT_LANGUAGE=en
